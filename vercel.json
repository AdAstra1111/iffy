    "api/entity-links-engine.ts": {
      "maxDuration": 300
    }
  },
  "headers": [
    {
      "source": "/(index.html)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-cache, no-store, must-revalidate"
        },
        {
          "key": "Surrogate-Control",
          "value": "no-store"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-cache, no-store, must-revalidate"
        },
        {
          "key": "Surrogate-Control",
          "value": "no-store"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/llm",
      "destination": "/api/llm"
    },
    {
      "source": "/api/nit-sync-proxy",
      "destination": "/api/nit-sync-proxy"
    },
    {
      "source": "/api/reverse-engineer-status-proxy",
      "destination": "/api/reverse-engineer-status-proxy"
    },
    {
      "source": "/((?!assets|favicon|og-image|robots|api).*)",
      "destination": "/index.html"
    }
  ],
